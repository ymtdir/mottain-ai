# Cloud SQL for PostgreSQL
DATABASE_URL=postgresql://mottain-ai:mottain-ai@localhost:5432/mottain-ai

# Google Cloud プロジェクト（Gemini Enterprise Agent Platform / Vertex AI）
# ローカル: gcloud auth application-default login で認証済みなら不要
# Cloud Run: サービスアカウントに Vertex AI User 権限を付与すれば不要
GOOGLE_CLOUD_PROJECT=gcp-project-id
GOOGLE_CLOUD_LOCATION=asia-northeast1

# デモ用ゲストアカウントの認証情報（ログイン画面で入力する値）
DEMO_NAME=demo-user
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=demo-password

# セッション Cookie の署名鍵。`openssl rand -base64 32` で生成した値を設定する
# 未設定だと開発用の固定値にフォールバックするため、本番・公開環境では必ず設定すること
SESSION_SECRET=session-secret
