# Cloud SQL for PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/mottain_ai

# Google Cloud プロジェクト（Gemini Enterprise Agent Platform / Vertex AI）
# ローカル: gcloud auth application-default login で認証済みなら不要
# Cloud Run: サービスアカウントに Vertex AI User 権限を付与すれば不要
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=asia-northeast1
