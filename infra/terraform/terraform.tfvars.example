# このファイルを terraform.tfvars にコピーして値を埋める（terraform.tfvars は git 管理外）
project_id        = "mottain-ai"
region            = "asia-northeast1"
service_name      = "mottain-ai"
repository_id     = "mottain-ai"
github_repository = "ymtdir/mottain-ai"

# Cloud SQL（PostgreSQL）。アプリの動作に必須
enable_cloud_sql = true
